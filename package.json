{
  "name": "builderforce-memory",
  "version": "2026.6.28",
  "private": true,
  "description": "BuilderForce Agent Memory — the memory subsystem of BuilderForce.ai. Engine (@seanhogg/builderforce-memory-engine) + runtime (@seanhogg/builderforce-memory) in one workspace.",
  "type": "module",
  "author": {
    "name": "Sean Hogg",
    "email": "seanhogg@gmail.com",
    "url": "https://builderforce.ai"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SeanHogg/builderforce-memory.git"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@9.1.0",
  "scripts": {
    "build": "pnpm --filter @seanhogg/builderforce-memory-engine build && pnpm --filter @seanhogg/builderforce-memory build && pnpm --filter @seanhogg/builderforce-memory-mcp build",
    "build:engine": "pnpm --filter @seanhogg/builderforce-memory-engine build",
    "build:memory": "pnpm --filter @seanhogg/builderforce-memory build",
    "build:mcp": "pnpm --filter @seanhogg/builderforce-memory-mcp build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r exec rimraf dist",
    "release:check": "pnpm build && pnpm test",
    "typecheck:native": "tsgo --noEmit"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "rimraf": "^5.0.0",
    "typescript": "^6.0.3",
    "@typescript/native-preview": "7.0.0-dev.20260627.2"
  }
}
