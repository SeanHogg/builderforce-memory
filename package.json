{
  "name": "builderforce-memory",
  "version": "2026.5.31",
  "private": true,
  "description": "BuilderForce Agent Memory — the memory subsystem of BuilderForce.ai. Engine (@builderforce/memory-engine) + runtime (@builderforce/memory) in one workspace.",
  "type": "module",
  "author": {
    "name": "Sean Hogg",
    "email": "seanhogg@gmail.com",
    "url": "https://builderforce.ai"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SeanHogg/builderforce-memory.git"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@9.1.0",
  "scripts": {
    "build": "pnpm --filter @builderforce/memory-engine build && pnpm --filter @builderforce/memory build",
    "build:engine": "pnpm --filter @builderforce/memory-engine build",
    "build:memory": "pnpm --filter @builderforce/memory build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r exec rimraf dist",
    "release:check": "pnpm build && pnpm test"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.0.0"
  }
}
