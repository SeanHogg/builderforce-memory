{
  "name": "@builderforce/memory-mcp",
  "version": "2026.6.18",
  "description": "BuilderForce Agent Memory — MCP transport. Exposes @builderforce/memory to any MCP client (Claude Agent SDK in-process, stdio, or HTTP) over a pluggable MemoryBackend, with token-saving fetch-on-demand recall.",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "builderforce-memory-mcp": "dist/bin/stdio.js",
    "builderforce-memory-mcp-http": "dist/bin/http.js"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "lint": "eslint src/",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude-agent-sdk",
    "agent-memory",
    "ssm",
    "builderforce",
    "typescript"
  ],
  "author": {
    "name": "Sean Hogg",
    "email": "seanhogg@gmail.com",
    "url": "https://builderforce.ai"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SeanHogg/builderforce-memory.git",
    "directory": "packages/memory-mcp"
  },
  "homepage": "https://github.com/SeanHogg/builderforce-memory/tree/main/packages/memory-mcp#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.23.0"
  },
  "peerDependencies": {
    "@anthropic-ai/claude-agent-sdk": ">=0.1.0",
    "@builderforce/memory": "^2026.6.18",
    "fake-indexeddb": "^6.0.0"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/claude-agent-sdk": { "optional": true },
    "@builderforce/memory": { "optional": true },
    "fake-indexeddb": { "optional": true }
  },
  "devDependencies": {
    "@anthropic-ai/claude-agent-sdk": ">=0.1.0",
    "@builderforce/memory": "workspace:*",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "fake-indexeddb": "^6.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
