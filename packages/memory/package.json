{
  "name": "@seanhogg/builderforce-memory",
  "version": "2026.6.36",
  "description": "BuilderForce Agent Memory — runtime layer. SSM execution, Transformer orchestration, online distillation, hybrid RAG retrieval, and persistent agent memory for BuilderForce.ai agents.",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./retrieval": {
      "types": "./dist/retrieval/index.d.ts",
      "import": "./dist/retrieval/index.js"
    }
  },
  "type": "module",
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "lint": "eslint src/ tests/",
    "prepublishOnly": "npm run build",
    "typecheck:native": "tsgo --noEmit"
  },
  "keywords": [
    "mamba",
    "ssm",
    "state-space-model",
    "webgpu",
    "ai-runtime",
    "distillation",
    "online-learning",
    "agent",
    "transformer-bridge",
    "browser-ai",
    "agent-memory",
    "builderforce",
    "typescript"
  ],
  "author": {
    "name": "Sean Hogg",
    "email": "seanhogg@gmail.com",
    "url": "https://builderforce.ai"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SeanHogg/builderforce-memory.git",
    "directory": "packages/memory"
  },
  "bugs": {
    "url": "https://github.com/SeanHogg/builderforce-memory/issues"
  },
  "homepage": "https://github.com/SeanHogg/builderforce-memory/tree/main/packages/memory#readme",
  "peerDependencies": {
    "@seanhogg/builderforce-memory-engine": "workspace:^"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/jest": "^29.5.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@webgpu/types": "^0.1.49",
    "@seanhogg/builderforce-memory-engine": "workspace:*",
    "eslint": "^8.57.0",
    "fake-indexeddb": "^6.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "typescript": "^6.0.3",
    "@typescript/native-preview": "7.0.0-dev.20260627.2"
  },
  "jest": {
    "preset": "ts-jest/presets/default-esm",
    "extensionsToTreatAsEsm": [
      ".ts"
    ],
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "useESM": true,
          "tsconfig": {
            "module": "ES2022",
            "moduleResolution": "bundler",
            "strict": false,
            "esModuleInterop": true,
            "skipLibCheck": true,
            "types": [
              "@webgpu/types",
              "jest"
            ]
          }
        }
      ]
    },
    "moduleNameMapper": {
      "^@seanhogg/builderforce-memory-engine$": "<rootDir>/../memory-engine/src/index.ts",
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/index.ts",
      "!src/session/**"
    ],
    "coverageThreshold": {
      "global": {
        "statements": 90,
        "branches": 85,
        "functions": 95,
        "lines": 92
      }
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
